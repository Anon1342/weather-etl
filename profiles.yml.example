weather_dbt:
  outputs:
    dev:
      dataset: your_dataset
      job_execution_timeout_seconds: 300
      job_retries: 1
      keyfile: /app/credentials.json
      location: your_location
      method: service-account
      priority: interactive
      project: Your_GCP_Project_ID
      threads: 1
      type: bigquery
  target: dev
